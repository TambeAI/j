import java.util.Scanner;

class Book {

    int bookId;
    String bookName;
    String author;
    boolean issued;

    static int totalBooks = 0;

    Book(int id, String name, String authorName) {
        bookId = id;
        bookName = name;
        author = authorName;
        issued = false;

        totalBooks++;
    }

    void displayBook() {

        System.out.println("Book ID : " + bookId);
        System.out.println("Book Name : " + bookName);
        System.out.println("Author : " + author);

        if(issued) {
            System.out.println("Status : Issued");
        } else {
            System.out.println("Status : Available");
        }

        System.out.println("---------------------------");
    }

    void issueBook() {

        if(issued) {
            System.out.println("Book already issued.");
        } else {
            issued = true;
            System.out.println("Book issued successfully.");
        }
    }

    void returnBook() {

        if(issued) {
            issued = false;
            System.out.println("Book returned successfully.");
        } else {
            System.out.println("Book was not issued.");
        }
    }

    static void showTotalBooks() {
        System.out.println("Total Books = " + totalBooks);
    }
}

public class Library{

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        Book b1 = new Book(101, "Java Programming", "James Gosling");
        Book b2 = new Book(102, "Python Basics", "Guido Van Rossum");
        Book b3 = new Book(103, "Data Structures", "Mark Allen");

        int choice;

        do {

            System.out.println("\n===== Library Management System =====");
            System.out.println("1. View All Books");
            System.out.println("2. Issue Book");
            System.out.println("3. Return Book");
            System.out.println("4. Show Total Books");
            System.out.println("5. Exit");

            System.out.print("Enter your choice: ");
            choice = sc.nextInt();

            switch(choice) {

                case 1:

                    b1.displayBook();
                    b2.displayBook();
                    b3.displayBook();

                    break;

                case 2:

                    System.out.print("Enter Book ID to issue: ");
                    int issueId = sc.nextInt();

                    if(issueId == 101) {
                        b1.issueBook();
                    }
                    else if(issueId == 102) {
                        b2.issueBook();
                    }
                    else if(issueId == 103) {
                        b3.issueBook();
                    }
                    else {
                        System.out.println("Invalid Book ID");
                    }

                    break;

                case 3:

                    System.out.print("Enter Book ID to return: ");
                    int returnId = sc.nextInt();

                    if(returnId == 101) {
                        b1.returnBook();
                    }
                    else if(returnId == 102) {
                        b2.returnBook();
                    }
                    else if(returnId == 103) {
                        b3.returnBook();
                    }
                    else {
                        System.out.println("Invalid Book ID");
                    }
                    
                    break;

                case 4:

                    Book.showTotalBooks();

                    break;

                case 5:

                    System.out.println("Exiting Program...");
                    break;

                default:

                    System.out.println("Invalid Choice!");
            }

        } while(choice != 5);

        sc.close();
    }
}
